{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/boreas-aquilo/constantia/main/schemas/rule.schema.json",
  "title": "Constantia rule catalogue",
  "description": "A rule binds a selector (which files) to a check (guided or llm_investigated). Every file the selector matches is scored — N matched = N verdicts, no silent skips. Findings from the two check types land in strictly separated report sections.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rules"],
  "properties": {
    "version": { "const": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    }
  },
  "$defs": {
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "concept_id", "name", "description", "severity", "selector", "type"],
      "properties": {
        "id":          { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$" },
        "concept_id":  { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$", "description": "Must reference a concept defined in concepts.yaml." },
        "name":        { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "severity":    { "enum": ["low", "medium", "high", "critical"] },
        "selector":    { "$ref": "#/$defs/selector" },
        "type":        { "enum": ["guided", "llm_investigated"] },
        "guided":           { "$ref": "#/$defs/guided" },
        "llm_investigated": { "$ref": "#/$defs/llm_investigated" }
      },
      "allOf": [
        {
          "if":   { "properties": { "type": { "const": "guided" } } },
          "then": { "required": ["guided"], "not": { "required": ["llm_investigated"] } }
        },
        {
          "if":   { "properties": { "type": { "const": "llm_investigated" } } },
          "then": { "required": ["llm_investigated"], "not": { "required": ["guided"] } }
        }
      ]
    },
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_glob"],
      "description": "Picks files from the repo. Every matched file is visibly scored. `file_contains_regex` is an optional cheap content filter that dramatically trims scan size without reading the file into the LLM.",
      "properties": {
        "file_glob":           { "type": "string", "minLength": 1 },
        "file_contains_regex": { "type": "string", "minLength": 1 },
        "exclude_globs":       { "type": "array", "items": { "type": "string" } }
      }
    },
    "guided": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check"],
      "description": "Static mechanical check — the registered check runs against each matched file and may itself perform cross-file lookups (e.g. grep handlers for each rpc listed here). Outputs land in the guided section of the report.",
      "properties": {
        "check":  { "type": "string", "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$", "description": "Name of a registered check under src/constantia/checks/." },
        "config": { "type": "object" }
      }
    },
    "llm_investigated": {
      "type": "object",
      "additionalProperties": false,
      "required": ["investigation"],
      "description": "LLM reads the concept's principle side-by-side with each matched file and judges fit. Stochastic; outputs land in the llm-investigated section and are adversarially re-verified before the report.",
      "properties": {
        "investigation":   { "type": "string", "minLength": 20 },
        "proof_required":  { "type": "boolean", "default": true },
        "model":           { "type": "string", "default": "mistral-medium-latest" }
      }
    }
  }
}
